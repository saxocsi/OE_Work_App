<Window x:Class="OE_Work_App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:OE_Work_App"
        mc:Ignorable="d"
        Title="Cocktail Stock Manager" Height="600" Width="1000">
    <Grid Margin="10">
        <TabControl>
            <TabItem Header="Ingredients">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal"
                                Margin="0 0 0 10">
                        <Button Content="Add"
                                Width="100"
                                Margin="0 0 10 0"
                                Click="AddIngredientBtn_Click"/>

                        <Button Content="Edit"
                                Width="100"
                                Margin="0 0 10 0"
                                Click="EditIngredientBtn_Click"/>

                        <Button Content="Delete"
                                Width="100"
                                Click="DeleteIngredientBtn_Click"/>
                    </StackPanel>

                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding Ingredients}"
                              SelectedItem="{Binding SelectedIngredient}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True">

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Id"
                                                Binding="{Binding Id}"/>

                            <DataGridTextColumn Header="Name"
                                                Binding="{Binding Name}"/>

                            <DataGridTextColumn Header="CL / adag"
                                                Binding="{Binding Cl}"/>

                            <DataGridTextColumn Header="Price / adag"
                                                Binding="{Binding Price}"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <TextBlock Grid.Row="2"
                               Text="{Binding Message}"
                               Margin="0 10 0 0"
                               FontWeight="Bold"/>
                </Grid>
            </TabItem>

            <TabItem Header="Cocktails">

                <Grid Margin="10">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal"
                    Margin="0 0 0 10">

                        <Button Content="Add"
                    Width="100"
                    Margin="0 0 10 0"
                    Click="AddCocktailBtn_Click"/>

                        <Button Content="Edit"
                    Width="100"
                    Margin="0 0 10 0"
                    Click="EditCocktailBtn_Click"/>

                        <Button Content="Delete"
                    Width="100"
                    Click="DeleteCocktailBtn_Click"/>

                    </StackPanel>

                    <DataGrid Grid.Row="1"
                  ItemsSource="{Binding Cocktails}"
                  SelectedItem="{Binding SelectedCocktail}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True">

                        <DataGrid.Columns>

                            <DataGridTextColumn Header="Id"
                                    Binding="{Binding Id}"/>

                            <DataGridTextColumn Header="Name"
                                    Binding="{Binding Name}"/>

                            <DataGridTextColumn Header="Glass"
                                    Binding="{Binding Glass.Name}"/>

                            <DataGridTextColumn Header="Total CL"
                                    Binding="{Binding TotalCl}"/>

                            <DataGridTextColumn Header="Price"
                                    Binding="{Binding Price}"/>

                            <DataGridCheckBoxColumn Header="Fits"
                                        Binding="{Binding FitsInGlass}"/>

                        </DataGrid.Columns>

                    </DataGrid>

                    <TextBlock Grid.Row="2"
                   Text="{Binding Message}"
                   Margin="0 10 0 0"
                   FontWeight="Bold"/>

                </Grid>

            </TabItem>
        </TabControl>
    </Grid>
</Window>
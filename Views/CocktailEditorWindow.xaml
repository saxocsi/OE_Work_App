<Window x:Class="OE_Work_App.Views.CocktailEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Koktél szerkesztő"
        Height="600"
        Width="850"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
            <TextBlock Text="Koktél neve:" VerticalAlignment="Center" Margin="0,0,5,0"/>
            <TextBox Width="200" Margin="0,0,20,0"
                     Text="{Binding CocktailName, UpdateSourceTrigger=PropertyChanged}"/>
            <TextBlock Text="Pohár:" VerticalAlignment="Center" Margin="0,0,5,0"/>
            <ComboBox Width="200"
                      ItemsSource="{Binding Glasses}"
                      SelectedItem="{Binding SelectedGlass}"
                      DisplayMemberPath="Name"/>
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,15">
            <ComboBox Width="220" Margin="0,0,10,0"
                      ItemsSource="{Binding Ingredients}"
                      SelectedItem="{Binding SelectedIngredient}"
                      DisplayMemberPath="Name"/>
            <TextBlock Text="Adag:" VerticalAlignment="Center" Margin="0,0,5,0"/>
            <TextBox Width="60" Margin="0,0,10,0"
                     Text="{Binding IngredientAmount, UpdateSourceTrigger=PropertyChanged}"/>
            <Button Content="Alapanyag hozzáadása" Width="170" Click="AddIngredientBtn_Click"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Margin="0,0,0,15">
            <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                <TextBlock Text="{Binding TotalCl, StringFormat=Összes mennyiség: {0} cl}"
                           FontWeight="Bold" Margin="0,0,20,0"/>
                <TextBlock Text="{Binding TotalPrice, StringFormat=Ár: {0} Ft}"
                           FontWeight="Bold" Margin="0,0,20,0"/>
            </StackPanel>
            <TextBlock Text="{Binding FitMessage}" FontWeight="Bold"/>
        </StackPanel>

        <DataGrid Grid.Row="3"
                  ItemsSource="{Binding CocktailIngredients}"
                  SelectedItem="{Binding SelectedCocktailIngredient}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Alapanyag" Binding="{Binding Ingredient.Name}" Width="*"/>
                <DataGridTextColumn Header="Adag" Binding="{Binding Amount}" Width="80"/>
                <DataGridTextColumn Header="Összes cl" Binding="{Binding TotalCl}" Width="100"/>
                <DataGridTextColumn Header="Ár (Ft)" Binding="{Binding TotalPrice}" Width="100"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="4"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,15,0,0">
            <Button Content="Alapanyag törlése" Width="150" Margin="0,0,10,0"
                    Click="DeleteIngredientBtn_Click"/>
            <Button Content="Mentés" Width="100" Margin="0,0,10,0"
                    Click="SaveBtn_Click"
                    IsEnabled="{Binding CanSave}"/>
            <Button Content="Mégse" Width="100" Click="CancelBtn_Click"/>
        </StackPanel>
    </Grid>
</Window>

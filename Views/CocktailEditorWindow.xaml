<Window x:Class="OE_Work_App.Views.CocktailEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cocktail Editor"
        Height="650"
        Width="900"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal"
                    Margin="0 0 0 15">

            <TextBlock Text="Cocktail name:"
                       VerticalAlignment="Center"
                       Margin="0 0 5 0"/>

            <TextBox Width="200"
                     Margin="0 0 20 0"
                     Text="{Binding CocktailName}"/>

            <TextBlock Text="Glass:"
                       VerticalAlignment="Center"
                       Margin="0 0 5 0"/>

            <ComboBox Width="180"
                      ItemsSource="{Binding Glasses}"
                      SelectedItem="{Binding SelectedGlass}"
                      DisplayMemberPath="Name"/>
        </StackPanel>

        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    Margin="0 0 0 15">

            <ComboBox Width="220"
                      Margin="0 0 10 0"
                      ItemsSource="{Binding Ingredients}"
                      SelectedItem="{Binding SelectedIngredient}"
                      DisplayMemberPath="Name"/>

            <TextBox Width="120"
                     Margin="0 0 10 0"
                     Text="{Binding IngredientAmount}"/>

            <Button Content="Add ingredient"
                    Width="150"
                    Click="AddIngredientBtn_Click"/>
        </StackPanel>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    Margin="0 0 0 15">

            <TextBlock Text="{Binding TotalCl, StringFormat=Total CL: {0}}"
                       FontSize="16"
                       FontWeight="Bold"
                       Margin="0 0 20 0"/>

            <TextBlock Text="{Binding TotalPrice, StringFormat=Price: {0} Ft}"
                       FontSize="16"
                       FontWeight="Bold"
                       Margin="0 0 20 0"/>

            <TextBlock Text="{Binding FitMessage}"
                       FontSize="16"
                       FontWeight="Bold"/>
        </StackPanel>

        <DataGrid Grid.Row="3"
                  ItemsSource="{Binding CocktailIngredients}"
                  SelectedItem="{Binding SelectedCocktailIngredient}"
                  AutoGenerateColumns="False">

            <DataGrid.Columns>

                <DataGridTextColumn Header="Ingredient"
                                    Binding="{Binding Ingredient.Name}"/>

                <DataGridTextColumn Header="Amount"
                                    Binding="{Binding Amount}"/>

                <DataGridTextColumn Header="Total CL"
                                    Binding="{Binding TotalCl}"/>

                <DataGridTextColumn Header="Total Price"
                                    Binding="{Binding TotalPrice}"/>

            </DataGrid.Columns>

        </DataGrid>

        <StackPanel Grid.Row="4"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0 15 0 0">

            <Button Content="Delete ingredient"
                    Width="150"
                    Margin="0 0 10 0"
                    Click="DeleteIngredientBtn_Click"/>

            <Button Content="Save"
                    Width="100"
                    Margin="0 0 10 0"
                    Click="SaveBtn_Click"/>

            <Button Content="Cancel"
                    Width="100"
                    Click="CancelBtn_Click"/>
        </StackPanel>

    </Grid>

</Window>